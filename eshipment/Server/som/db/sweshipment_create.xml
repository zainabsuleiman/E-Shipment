<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE create SYSTEM "http://strategyobject.com/dtd/create.dtd">
<create>
    <!--================================================== -->
    <!-- SHIPMENT_TRANSFER_NOTES - Main document table     -->
    <!-- Maps to TC_ShipmentGen                            -->
    <!--================================================== -->
    <table name="SHIPMENT_TRANSFER_NOTES">
        <!-- Instance ID (required unique identifier) -->
        <column name="INSTANCEID"    type="INTEGER"   null="false"/>

        <!-- Header Information (HDR) -->
        <column name="SHP_REF_NBR"   type="VARCHAR"   size="30"/>
        <column name="SHP_TRD_TIN"   type="VARCHAR"   size="15"/>
        <column name="SHP_PLT_NBR"   type="VARCHAR"   size="15"/>
        <column name="SHP_DRV_NAM"   type="VARCHAR"   size="100"/>
        <column name="SHP_SEL_NBR"   type="VARCHAR"   size="20"/>

        <!-- Route Information (RTE) -->
        <column name="SHP_WH_SOURCE" type="VARCHAR"   size="10"/>
        <column name="SHP_WH_TARGET" type="VARCHAR"   size="10"/>
        <column name="SHP_DEP_DATE"  type="TIMESTAMP"/>
        <column name="SHP_ARV_DATE"  type="TIMESTAMP"/>

        <!-- Global Status -->
        <column name="SHP_STATUS"    type="VARCHAR"   size="20"/>

        <!-- Primary Key -->
        <primary_key>
            <column name="INSTANCEID"/>
        </primary_key>

        <!-- Indexes for Fast Search (F_Shipment) -->
        <index name="IDX_SHP_REF">
            <column name="SHP_REF_NBR"/>
        </index>
        <index name="IDX_SHP_WH_FROM">
            <column name="SHP_WH_SOURCE"/>
        </index>
        <index name="IDX_SHP_PLT">
            <column name="SHP_PLT_NBR"/>
        </index>
    </table>

    <!-- ================================================== -->
    <!-- SHIPMENT_CARGO_ITEMS - Multi-line Cargo Table      -->
    <!-- Maps to the CRG Segment                            -->
    <!-- ================================================== -->
    <table name="SHIPMENT_CARGO_ITEMS">
        <column name="INSTANCEID" type="INTEGER" null="false"/>
        <column name="KEY_RNK"    type="INTEGER" null="false"/>
        <column name="HS_CODE"    type="VARCHAR" size="12"/>
        <column name="PKG_COUNT"  type="INTEGER"/>
        <primary_key>
            <column name="INSTANCEID"/>
            <column name="KEY_RNK"/>
        </primary_key>
    </table>
</create>
